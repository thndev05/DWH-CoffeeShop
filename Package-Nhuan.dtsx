                      description="Specifies a SQL statement that uses parameters to generate the lookup table."
                      expressionType="Notify"
                      name="SqlCommandParam"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">select * from (SELECT DateKey, CAST(FullDate AS DATETIME) AS FullDate
FROM dbo.Dim_Date) [refTable]
where [refTable].[FullDate] = ?</property>
