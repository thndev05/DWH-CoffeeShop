          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{FD1719CD-FB8F-429F-9070-24ACDC59B0E2}"
              SQLTask:SqlStatementSource="-- 1. Xóa dữ liệu bảng Fact trước (Ngọn)&#xA;DELETE FROM [dbo].[Fact_Sales];&#xA;&#xA;-- 2. Xóa dữ liệu các bảng Dim (Gốc)&#xA;DELETE FROM [dbo].[Dim_Store];&#xA;DELETE FROM [dbo].[Dim_Product];&#xA;DELETE FROM [dbo].[Dim_User];&#xA;DELETE FROM [dbo].[Dim_Date];&#xA;DELETE FROM [dbo].[Dim_Time];&#xA;&#xA;-- 3. Reset lại số tự tăng (ID) về 1 cho các bảng&#xA;-- Vì DELETE không tự reset số ID như TRUNCATE nên cần thêm các dòng này&#xA;DBCC CHECKIDENT ('[dbo].[Dim_Store]', RESEED, 0);&#xA;DBCC CHECKIDENT ('[dbo].[Dim_Product]', RESEED, 0);&#xA;DBCC CHECKIDENT ('[dbo].[Dim_User]', RESEED, 0);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
    </DTS:Executable>
